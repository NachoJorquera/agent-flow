{
  "name": "agent-flow-desktop",
  "version": "0.1.0",
  "private": true,
  "main": "dist/main/main.js",
  "scripts": {
    "build:main": "node esbuild.main.mjs",
    "build:renderer": "cd ../web && pnpm run build:electron",
    "build": "npm run build:main && npm run build:renderer",
    "test": "vitest run",
    "test:watch": "vitest",
    "dev:main": "node esbuild.main.mjs --watch",
    "dev:renderer": "cd ../web && pnpm exec vite --config vite.config.electron.ts",
    "dev": "concurrently \"npm run dev:main\" \"npm run dev:renderer\" \"wait-on http://localhost:5173 file:dist/main/main.js && ELECTRON_RENDERER_URL=http://localhost:5173 electron .\"",
    "start": "electron .",
    "package": "npm run build && electron-builder --mac dmg"
  },
  "dependencies": {
    "electron-store": "^10.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "concurrently": "^9.1.2",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "esbuild": "^0.20.2",
    "typescript": "^5.7.3",
    "vitest": "^3.2.4",
    "wait-on": "^8.0.1"
  }
}
